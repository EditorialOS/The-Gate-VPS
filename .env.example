# ── The Gate MCP — environment template ──────────────────────────────
# Copy to .env and fill in. NEVER commit the real .env.

# Base URL of The Gate API as reachable from inside the Docker network.
GATE_API_BASE_URL=http://api:8080/api

# Path to the bundled OpenAPI spec inside the container.
SPEC_FILE=/app/openapi.yaml

# Port the MCP server listens on (Traefik routes to this).
PORT=3000

# ── NOT used by the MCP server, documented here for operators ─────────
# The admin secret lives ONLY in the API container's env (the-gate).
# provision-customer.sh reads it at runtime via 'docker exec the-gate printenv'.
# GATE_ADMIN_SECRET=<set on the API container, not here>
